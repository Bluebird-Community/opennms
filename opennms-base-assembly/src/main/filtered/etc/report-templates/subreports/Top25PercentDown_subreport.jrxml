			<text><![CDATA[Down]]></text>
		</element>
		<element kind="staticText" uuid="22996c8a-971c-4953-941d-7689bd867fbd" x="0" y="0" width="299" height="20" style="Sub-sub-header">
			<text><![CDATA[Top 25 Nodes Down (%)]]></text>
		</element>
	</columnHeader>
	<detail>
		<band height="20" splitType="Stretch">
			<element kind="textField" uuid="7e519183-11a0-4449-8eb9-31bc9f26dbde" x="0" y="0" width="148" height="20" style="Body">
				<expression><![CDATA[$F{nodelabel}]]></expression>
			</element>
			<element kind="textField" uuid="b86e13d7-0d5c-45fb-affa-43baa2803ce2" x="148" y="0" width="151" height="20" pattern="###0.00" hTextAlign="Right" style="Body">
				<expression><![CDATA[String.format("%10.2f", $F{outages_percent}) + "%"]]></expression>
			</element>
		</band>
	</detail>
	<noData height="50"/>
</jasperReport>
