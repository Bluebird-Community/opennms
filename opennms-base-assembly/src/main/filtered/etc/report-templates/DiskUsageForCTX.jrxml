<jasperReport name="C Disk Usage for CTX" language="java" pageWidth="595" pageHeight="842" whenNoDataType="NoDataSection" columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="da414e98-a94f-493f-8026-9816e5e66edd">
