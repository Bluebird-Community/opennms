<jasperReport name="InterfaceUtilizationSummary_subreport" language="java" pageWidth="555" pageHeight="802" whenNoDataType="NoDataSection" columnWidth="555" leftMargin="0" rightMargin="0" topMargin="0" bottomMargin="0" uuid="31dde554-de85-40d3-a879-e2cf7990b672">
	<property name="net.sf.jasperreports.chart.pie.ignore.duplicated.key" value="true"/>
	<property name="ireport.zoom" value="1.8150000000000004"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<template><![CDATA[$P{ONMS_REPORT_DIR} + "/assets/styles/defaultStyles.jrtx"]]></template>
	<parameter name="ONMS_REPORT_DIR" class="java.lang.String">
		<description><![CDATA[The directory where all reports can be found]]></description>
		<defaultValueExpression><![CDATA["${install.dir}/etc/report-templates"]]></defaultValueExpression>
	</parameter>
	<parameter name="nodeid" class="java.lang.Integer"/>
	<parameter name="foreignsource" class="java.lang.String"/>
	<parameter name="foreignid" class="java.lang.String"/>
	<parameter name="startDate" class="java.util.Date"/>
	<parameter name="endDate" class="java.util.Date"/>
	<parameter name="snmpifalias" class="java.lang.String"/>
	<parameter name="snmpifname" class="java.lang.String"/>
	<parameter name="snmpifdescr" class="java.lang.String"/>
	<parameter name="snmpphysaddr" class="java.lang.String"/>
	<parameter name="snmpifspeed" class="java.lang.Long"/>
	<parameter name="ifLabel" forPrompting="false" class="java.lang.String">
		<defaultValueExpression><![CDATA[$P{snmpifname} == null || "".equals($P{snmpifname}) ? $P{snmpifdescr} : $P{snmpifname}]]></defaultValueExpression>
	</parameter>
	<parameter name="interface" forPrompting="false" class="java.lang.String">
		<description><![CDATA[]]></description>
		<defaultValueExpression><![CDATA[org.opennms.netmgt.jasper.helper.MeasurementsHelper.getInterfaceDescriptor($P{snmpifname}, $P{snmpifdescr}, $P{snmpphysaddr})]]></defaultValueExpression>
	</parameter>
	<parameter name="startDateTime" forPrompting="false" class="java.lang.Long">
		<defaultValueExpression><![CDATA[$P{startDate}.getTime()]]></defaultValueExpression>
	</parameter>
	<parameter name="endDateTime" forPrompting="false" class="java.lang.Long">
		<defaultValueExpression><![CDATA[$P{endDate}.getTime()]]></defaultValueExpression>
	</parameter>
	<parameter name="nodeResourceDescriptor" forPrompting="false" class="java.lang.String">
		<defaultValueExpression><![CDATA[org.opennms.netmgt.jasper.helper.MeasurementsHelper.getNodeOrNodeSourceDescriptor(String.valueOf($P{nodeid}), $P{foreignsource}, $P{foreignid})]]></defaultValueExpression>
	</parameter>
	<parameter name="MEASUREMENT_URL" class="java.lang.String"/>
	<parameter name="MEASUREMENT_USERNAME" class="java.lang.String"/>
	<parameter name="MEASUREMENT_PASSWORD" class="java.lang.String"/>
	<query language="Measurement"><![CDATA[<query-request step="300000" start="$P{startDateTime}" end="$P{endDateTime}" maxrows="2000">
  <source aggregation="AVERAGE" label="IfInOctets" attribute="ifHCInOctets" fallback-attribute="ifInOctets" transient="false" resourceId="$P{nodeResourceDescriptor}.interfaceSnmp[$P{interface}]"/>
  <source aggregation="AVERAGE" label="IfOutOctets" attribute="ifHCOutOctets" fallback-attribute="ifOutOctets" transient="false" resourceId="$P{nodeResourceDescriptor}.interfaceSnmp[$P{interface}]"/>
</query-request>]]></query>
	<field name="timestamp" class="java.util.Date">
		<description><![CDATA[]]></description>
	</field>
	<field name="IfInOctets" class="java.lang.Double">
		<description><![CDATA[]]></description>
	</field>
	<field name="IfOutOctets" class="java.lang.Double">
		<description><![CDATA[]]></description>
	</field>
	<variable name="received_SUM" calculation="Sum" class="java.lang.Double">
		<expression><![CDATA[$F{IfInOctets}]]></expression>
	</variable>
	<variable name="received_AVERAGE" calculation="Average" class="java.lang.Double">
		<expression><![CDATA[$F{IfInOctets}]]></expression>
	</variable>
	<variable name="received_STDDEV" calculation="StandardDeviation" class="java.lang.Double">
		<expression><![CDATA[$F{IfInOctets}]]></expression>
	</variable>
	<variable name="received_RATE_BYTES" class="java.lang.Double">
		<expression><![CDATA[($V{received_AVERAGE}+1.64485*$V{received_STDDEV})]]></expression>
	</variable>
	<variable name="received_RATE_BITS" class="java.lang.Double">
		<expression><![CDATA[$V{received_RATE_BYTES} * 8.0]]></expression>
	</variable>
	<variable name="transmitted_SUM" calculation="Sum" class="java.lang.Double">
		<expression><![CDATA[$F{IfOutOctets}]]></expression>
	</variable>
	<variable name="transmitted_AVERAGE" calculation="Average" class="java.lang.Double">
		<expression><![CDATA[$F{IfOutOctets}]]></expression>
	</variable>
	<variable name="transmitted_STDDEV" calculation="StandardDeviation" class="java.lang.Double">
		<expression><![CDATA[$F{IfOutOctets}]]></expression>
	</variable>
	<variable name="transmitted_RATE_BYTES" class="java.lang.Double">
		<expression><![CDATA[($V{transmitted_AVERAGE}+1.64485*$V{transmitted_STDDEV})]]></expression>
	</variable>
	<variable name="transmitted_RATE_BITS" class="java.lang.Double">
		<expression><![CDATA[$V{transmitted_RATE_BYTES} * 8.0]]></expression>
	</variable>
	<filterExpression><![CDATA[!$F{IfInOctets}.isNaN() || !$F{IfOutOctets}.isNaN()]]></filterExpression>
	<background splitType="Stretch"/>
	<title splitType="Stretch"/>
	<pageHeader splitType="Stretch"/>
	<columnHeader splitType="Stretch"/>
	<detail>
		<band splitType="Stretch"/>
	</detail>
	<columnFooter splitType="Stretch"/>
	<pageFooter splitType="Stretch"/>
	<summary height="200" splitType="Stretch">
		<element kind="textField" uuid="f2cfacd6-7128-4b9b-a5c3-32d6f886ad28" x="0" y="20" width="140" height="20" style="Body">
			<expression><![CDATA[$P{snmpifname} != null ? $P{snmpifname} : $P{snmpifdescr}]]></expression>
		</element>
		<element kind="textField" uuid="d34c0ecc-62dd-48ce-a9d0-dcff5ea041a5" x="298" y="20" width="120" height="20" backcolor="#333333" pattern="#,##0.00" hTextAlign="Right" style="Body">
			<expression><![CDATA[$V{transmitted_RATE_BITS} > 1048576 ? String.format("%10.2f", $V{transmitted_RATE_BITS}/new Double("1048576.0")) + " mb/s" : String.format("%10.2f", $V{transmitted_RATE_BITS}/new Double("1024.0")) + " kb/s"]]></expression>
		</element>
		<element kind="textField" uuid="e23392b1-c9c8-4ed2-bddf-ad441e5a74fb" x="435" y="20" width="120" height="20" pattern="#,##0.00" hTextAlign="Right" style="Body">
			<expression><![CDATA[$P{snmpifspeed} > 1048576 ? String.format("%10.2f", $P{snmpifspeed}/new Double("1048576.0")) + " mb/s" : String.format("%10.2f", $P{snmpifspeed}/new Double("1024.0")) + " kb/s"]]></expression>
		</element>
		<element kind="textField" uuid="efe8ae55-08b4-4664-9192-bc9c7d5ba845" x="158" y="20" width="120" height="20" backcolor="#CC9900" pattern="#,##0.00" hTextAlign="Right" style="Body">
			<expression><![CDATA[$V{received_RATE_BITS} > 1048576 ? String.format("%10.2f", $V{received_RATE_BITS}/new Double("1048576.0")) + " mb/s" : String.format("%10.2f", $V{received_RATE_BITS}/new Double("1024.0")) + " kb/s"]]></expression>
		</element>
		<element kind="chart" chartType="pie" uuid="6d7d1823-978f-4db8-884e-6d83b1688e47" x="158" y="51" width="140" height="140" showLegend="true">
			<dataset kind="pie">
				<series>
					<keyExpression><![CDATA["receive rate"]]></keyExpression>
					<valueExpression><![CDATA[$V{received_RATE_BITS}]]></valueExpression>
				</series>
				<series>
					<keyExpression><![CDATA["interface rate"]]></keyExpression>
					<valueExpression><![CDATA[new Double("" + $P{snmpifspeed}) - $V{received_RATE_BITS}]]></valueExpression>
				</series>
			</dataset>
			<plot>
				<itemLabel color="#000000" backgroundColor="#FFFFFF"/>
			</plot>
		</element>
		<element kind="chart" chartType="pie" uuid="2ada0f36-81b8-49e3-ae01-953ff0816f56" x="303" y="51" width="140" height="140" showLegend="true">
			<dataset kind="pie">
				<series>
					<keyExpression><![CDATA["transmitted rate"]]></keyExpression>
					<valueExpression><![CDATA[$V{transmitted_RATE_BITS}]]></valueExpression>
				</series>
				<series>
					<keyExpression><![CDATA["interface rate"]]></keyExpression>
					<valueExpression><![CDATA[new Double("" + $P{snmpifspeed}) - $V{transmitted_RATE_BITS}]]></valueExpression>
				</series>
			</dataset>
			<plot>
				<itemLabel color="#000000" backgroundColor="#FFFFFF"/>
			</plot>
		</element>
