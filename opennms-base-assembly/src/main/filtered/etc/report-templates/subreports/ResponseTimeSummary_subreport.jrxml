<jasperReport name="ResponseTimeSummary_subreport" language="java" pageWidth="555" pageHeight="802" whenNoDataType="NoDataSection" columnWidth="555" leftMargin="0" rightMargin="0" topMargin="0" bottomMargin="0" uuid="87b66934-3252-4957-ac31-b0207fd80659">
	<property name="ireport.zoom" value="2.0"/>
	<property name="ireport.x" value="240"/>
	<property name="ireport.y" value="0"/>
	<template><![CDATA[$P{ONMS_REPORT_DIR} + "/assets/styles/defaultStyles.jrtx"]]></template>
	<style name="Node_Group" mode="Opaque" backcolor="#DFDFDF" hTextAlign="Center" vTextAlign="Middle" hImageAlign="Center" vImageAlign="Middle" fontSize="10.0" bold="false" italic="false" underline="false" strikeThrough="false"/>
	<style name="Detail" hTextAlign="Center" vTextAlign="Middle" hImageAlign="Center" vImageAlign="Middle"/>
	<style name="Interface_Header" hTextAlign="Center" vTextAlign="Middle" hImageAlign="Center" vImageAlign="Middle" bold="true" italic="false" underline="false" strikeThrough="false"/>
	<parameter name="ONMS_REPORT_DIR" class="java.lang.String">
		<description><![CDATA[The directory where all reports can be found]]></description>
		<defaultValueExpression><![CDATA["${install.dir}/etc/report-templates"]]></defaultValueExpression>
	</parameter>
	<parameter name="MEASUREMENT_URL" class="java.lang.String"/>
	<parameter name="MEASUREMENT_USERNAME" class="java.lang.String"/>
	<parameter name="MEASUREMENT_PASSWORD" class="java.lang.String"/>
	<parameter name="nodeid" class="java.lang.String"/>
	<parameter name="foreignid" class="java.lang.String"/>
	<parameter name="foreignsource" class="java.lang.String"/>
	<parameter name="startDate" class="java.util.Date"/>
	<parameter name="endDate" class="java.util.Date"/>
	<parameter name="startDateTime" forPrompting="false" class="java.lang.Long">
		<defaultValueExpression><![CDATA[$P{startDate}.getTime()]]></defaultValueExpression>
	</parameter>
	<parameter name="endDateTime" forPrompting="false" class="java.lang.Long">
		<defaultValueExpression><![CDATA[$P{endDate}.getTime()]]></defaultValueExpression>
	</parameter>
	<parameter name="ipv4_interface" class="java.lang.String"/>
	<parameter name="nodeResourceDescriptor" forPrompting="false" class="java.lang.String">
		<defaultValueExpression><![CDATA[org.opennms.netmgt.jasper.helper.MeasurementsHelper.getNodeOrNodeSourceDescriptor($P{nodeid}, $P{foreignsource}, $P{foreignid})]]></defaultValueExpression>
	</parameter>
	<query language="measurement"><![CDATA[<query-request step="300000" start="$P{startDateTime}" end="$P{endDateTime}" maxrows="5000">
  <source aggregation="AVERAGE" label="IcmpLatency" attribute="icmp" transient="false" resourceId="$P{nodeResourceDescriptor}.responseTime[$P{ipv4_interface}]"/>
</query-request>]]></query>
	<field name="timestamp" class="java.util.Date">
		<description><![CDATA[Timestamp]]></description>
	</field>
	<field name="IcmpLatency" class="java.lang.Double">
		<description><![CDATA[IcmpLatency]]></description>
	</field>
	<variable name="ICMP_Latency_AVG" calculation="Average" class="java.lang.Double">
		<expression><![CDATA[$F{IcmpLatency}]]></expression>
	</variable>
	<variable name="ICMP_Latency_MIN" calculation="Lowest" class="java.lang.Double">
		<expression><![CDATA[$F{IcmpLatency}]]></expression>
	</variable>
	<variable name="ICMP_Latency_MAX" calculation="Highest" class="java.lang.Double">
		<expression><![CDATA[$F{IcmpLatency}]]></expression>
	</variable>
	<filterExpression><![CDATA[!$F{IcmpLatency}.isNaN()]]></filterExpression>
	<background splitType="Stretch"/>
	<title splitType="Stretch"/>
	<pageHeader splitType="Stretch"/>
	<columnHeader splitType="Stretch">
		<property name="local_mesure_unitheight" value="pixel"/>
		<property name="com.jaspersoft.studio.unit.height" value="px"/>
	</columnHeader>
	<detail>
		<band splitType="Stretch"/>
	</detail>
	<columnFooter splitType="Stretch"/>
	<pageFooter splitType="Stretch"/>
	<summary height="45" splitType="Stretch">
		<element kind="textField" uuid="9e00ed09-de3c-4660-b244-f38d5800bddd" x="25" y="20" width="230" height="20" hTextAlign="Left" style="Body">
			<expression><![CDATA[$P{ipv4_interface}]]></expression>
		</element>
