<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xmlns:onmsgi="http://xmlns.opennms.org/xsd/spring/onms-osgi"
       xsi:schemaLocation="http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans-4.2.xsd
        http://xmlns.opennms.org/xsd/spring/onms-osgi http://xmlns.opennms.org/xsd/spring/onms-osgi.xsd">

    <!--
      Wires the runtime side of collector token authentication.

      CollectorTokenAuthConfigFactory is a static-singleton-style factory;
      TokenProviderImpl handles its lazy init internally so a clean install
      without etc/collector-token-auth-configuration.xml degrades to "no
      token-auth definitions, every ${token:<name>} placeholder falls
      through" rather than failing at startup.
    -->

    <bean id="collectorTokenAuthAcquirer"
          class="org.opennms.netmgt.config.collectortokenauth.TokenAcquirer">
        <property name="entityScopeProvider" ref="entityScopeProvider"/>
    </bean>

    <bean id="collectorTokenAuthCache"
          class="org.opennms.netmgt.config.collectortokenauth.TokenCache">
        <constructor-arg ref="collectorTokenAuthAcquirer"/>
    </bean>

    <bean id="collectorTokenAuthProvider"
          class="org.opennms.netmgt.config.collectortokenauth.TokenProviderImpl">
        <constructor-arg ref="collectorTokenAuthCache"/>
    </bean>

    <!--
      Expose the TokenProvider as an OSGi service so the XML/JSON and HTTP
      collectors can autowire it without depending on opennms-config
      directly.
    -->
    <onmsgi:service interface="org.opennms.netmgt.config.collectortokenauth.TokenProvider"
                    ref="collectorTokenAuthProvider"/>

    <!--
      Mate scope that resolves ${token:<name>} placeholders during
      parameter interpolation. Chained into Collectd's scope chain via
      Collectd.m_tokenAuthScope so Interpolator can substitute tokens
      before the adaptor runs. The ambient scope passed to TokenProvider
      is SCV + ENV so token-auth definitions can reference credentials.
    -->
    <bean id="tokenAuthScopeAmbient" class="org.opennms.core.mate.api.FallbackScope">
        <constructor-arg>
            <list>
                <bean factory-bean="entityScopeProvider" factory-method="getScopeForScv"/>
                <bean factory-bean="entityScopeProvider" factory-method="getScopeForEnv"/>
            </list>
        </constructor-arg>
    </bean>

    <bean id="tokenAuthScope"
          class="org.opennms.netmgt.config.collectortokenauth.TokenAuthScope">
        <qualifier value="additionalScope"/>
        <constructor-arg ref="collectorTokenAuthProvider"/>
        <constructor-arg ref="tokenAuthScopeAmbient"/>
    </bean>

    <!--
      Collector adaptor that records which token-auth names participated
      in a request so the cache can be invalidated when the collection
      comes back failed. Substitution itself is done by tokenAuthScope
      during Mate interpolation, before the adaptor runs.
    -->
    <bean id="collectorTokenAuthAdaptor"
          class="org.opennms.netmgt.config.collectortokenauth.CollectorTokenAuthAdaptor">
        <constructor-arg ref="collectorTokenAuthProvider"/>
    </bean>

    <onmsgi:service interface="org.opennms.netmgt.collection.api.CollectorAdaptor"
                    ref="collectorTokenAuthAdaptor"/>

    <!--
      Reload listener: reacts to a reloadDaemonConfig event with
      daemonName=CollectorTokenAuth by re-reading
      collector-token-auth-configuration.xml and flushing the token cache.

      Registration is lazy via ContextRefreshedEvent. This bean lives in
      daoContext, which is loaded as a parent of eventDaemonContext while
      that context is still being constructed, so eventIpcManager is not
      yet available at construction or init time. The listener watches
      for context-refresh events and registers once
      EventIpcManagerFactory reports a ready manager.
    -->
    <bean id="collectorTokenAuthConfigReloadListener"
          class="org.opennms.netmgt.config.collectortokenauth.CollectorTokenAuthConfigReloadListener">
        <constructor-arg ref="collectorTokenAuthCache"/>
    </bean>

</beans>
