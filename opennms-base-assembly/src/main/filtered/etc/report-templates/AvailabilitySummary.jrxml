				<element kind="subreport" uuid="78dfca67-64b5-47c1-99c7-80331e054ad6" x="0" y="300" width="553" height="212">
					<connectionExpression><![CDATA[$P{REPORT_CONNECTION}]]></connectionExpression>
					<expression><![CDATA[$P{SUBREPORT_DIR} + "AvailabilitySummaryChart_subreport.jasper"]]></expression>
