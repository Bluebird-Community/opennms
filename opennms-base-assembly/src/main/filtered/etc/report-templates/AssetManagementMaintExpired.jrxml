	<style name="expire_warning_MARK" mode="Transparent" hTextAlign="Center" vTextAlign="Middle" hImageAlign="Center" vImageAlign="Middle" rotation="Left" markup="styled">
		<conditionalStyle mode="Opaque" forecolor="#FF9900" backcolor="#FFCC66" rotation="Left" bold="true" italic="false" underline="false" strikeThrough="false">
			<conditionExpression><![CDATA["expired".equals($F{maintcontractstatus})]]></conditionExpression>
		</conditionalStyle>
	</style>
	<style name="expire_warning_TD" mode="Opaque" backcolor="#FFFFFF" hTextAlign="Left" vTextAlign="Middle" hImageAlign="Left" vImageAlign="Middle">
		<conditionalStyle mode="Opaque" forecolor="#000000" backcolor="#FFCC66">
			<conditionExpression><![CDATA["expired".equals($F{maintcontractstatus})]]></conditionExpression>
		</conditionalStyle>
	</style>
	<style name="negativ_days" vTextAlign="Middle" vImageAlign="Middle">
		<conditionalStyle forecolor="#CC3300">
			<conditionExpression><![CDATA[new Boolean($F{maintcontractleft}.getDays() < new Integer("0"))]]></conditionExpression>
		</conditionalStyle>
	</style>
	<dataset name="summaryByNode" uuid="f453a7a0-8025-4d1a-8a9e-1a73fd442cd7">
		<parameter name="DS_DISPLAY_EXPIRED" forPrompting="false" class="java.lang.String">
			<defaultValueExpression><![CDATA["true"]]></defaultValueExpression>
		</parameter>
		<parameter name="DS_WARN_THRESH" forPrompting="false" class="java.lang.Integer">
			<defaultValueExpression><![CDATA[30]]></defaultValueExpression>
		</parameter>
		<parameter name="DS_DATE_FORMAT" forPrompting="false" class="java.lang.String">
			<defaultValueExpression><![CDATA["YYYY-MM-DD"]]></defaultValueExpression>
		</parameter>
		<query language="sql"><![CDATA[SELECT
	n.nodelabel,
	a.manufacturer,
	a.maintcontract,
	to_date(a.maintcontractexpires,'$P!{DS_DATE_FORMAT}') AS expire,
	CASE
		WHEN
			to_date(a.maintcontractexpires,'$P!{DS_DATE_FORMAT}') - now() < INTERVAL '0 days'
 			THEN 'expired'
		ELSE
			'warning'
	END AS maintcontractstatus,
	'1'::INTEGER AS count
FROM
	public.assets a
JOIN
	public.node n
ON
	a.nodeid = n.nodeid
WHERE
	n.nodetype = 'A' AND
	a.maintcontract IS NOT NULL  AND
	a.maintcontractexpires IS NOT NULL  AND
	a.maintcontractexpires != '' AND
	a.maintcontractexpires != 'n.v.' AND
	a.maintcontract != 'n.v.' AND
	a.maintcontract != '' AND
	to_date(a.maintcontractexpires,'$P!{DS_DATE_FORMAT}') - now() < INTERVAL '$P!{DS_WARN_THRESH} days'
GROUP BY
	n.nodelabel,
	a.manufacturer,
	a.maintcontract,
	a.maintcontractexpires,
	maintcontractstatus
ORDER BY
	expire ASC,
	a.manufacturer,
	a.maintcontract]]></query>
		<field name="nodelabel" class="java.lang.String"/>
		<field name="manufacturer" class="java.lang.String"/>
		<field name="maintcontract" class="java.lang.String"/>
		<field name="expire" class="java.sql.Date"/>
		<field name="maintcontractstatus" class="java.lang.String"/>
		<field name="count" class="java.lang.Integer"/>
		<variable name="expired_SUM" resetType="Group" calculation="Sum" resetGroup="warning" class="java.lang.Integer">
			<expression><![CDATA[$F{count}]]></expression>
		</variable>
		<variable name="total_SUM" calculation="Sum" class="java.lang.Integer">
			<expression><![CDATA[$F{count}]]></expression>
		</variable>
		<filterExpression><![CDATA["true".equals($P{DS_DISPLAY_EXPIRED}) ? !"".equals($F{maintcontractstatus}) : "warning".equals($F{maintcontractstatus})]]></filterExpression>
		<group name="warning">
			<expression><![CDATA[$F{maintcontractstatus}]]></expression>
		</group>
	</dataset>
	<parameter name="ONMS_REPORT_DIR" forPrompting="false" class="java.lang.String">
		<description><![CDATA[The directory where all reports can be found]]></description>
		<defaultValueExpression><![CDATA["${install.dir}/etc/report-templates"]]></defaultValueExpression>
	</parameter>
	<parameter name="WARNING_THRESHOLD_DAYS" class="java.lang.Integer">
		<description><![CDATA[Warning threshold for contract expiration]]></description>
		<defaultValueExpression><![CDATA[20]]></defaultValueExpression>
	</parameter>
	<parameter name="DISPLAY_EXPIRED" class="java.lang.String">
		<description><![CDATA[Show expired mainenance contracts (true/false)]]></description>
		<defaultValueExpression><![CDATA["true"]]></defaultValueExpression>
	</parameter>
	<parameter name="COMPANY_LOGO" forPrompting="false" class="java.lang.String">
		<description><![CDATA[Company logo]]></description>
		<defaultValueExpression><![CDATA[$P{ONMS_REPORT_DIR} + "/assets/images/company-logo.png"]]></defaultValueExpression>
	</parameter>
	<parameter name="DATE_FORMAT" class="java.lang.String">
		<description><![CDATA[Format for expire date. Default: "YYYY-MM-DD"]]></description>
		<defaultValueExpression><![CDATA["YYYY-MM-DD"]]></defaultValueExpression>
	</parameter>
	<query language="SQL"><![CDATA[SELECT
	n.nodelabel,
	a.maintcontract,
	a.manufacturer,
	a.modelnumber,
	a.operatingsystem,
	a.serialnumber,
	to_date(a.dateinstalled,'$P!{DATE_FORMAT}') as dateinstalled,
	a.vendorphone,
	to_date(a.maintcontractexpires,'$P!{DATE_FORMAT}') AS maintcontractexpires,
	to_date(a.maintcontractexpires,'$P!{DATE_FORMAT}') - now() AS maintcontractleft,
	CASE
		WHEN
			to_date(a.maintcontractexpires,'$P!{DATE_FORMAT}') - now() < INTERVAL '$P!{WARNING_THRESHOLD_DAYS} days'
 			THEN 'expired'
		ELSE
			'warning'
	END AS maintcontractstatus
FROM
	public.assets a
JOIN
	public.node n
ON
	a.nodeid = n.nodeid
WHERE
	n.nodetype = 'A' AND
	a.maintcontract IS NOT NULL  AND
	a.maintcontractexpires IS NOT NULL  AND
	a.maintcontractexpires != '' AND
	a.maintcontractexpires != 'n.v.' AND
	a.maintcontract != 'n.v.' AND
	a.maintcontract != '' AND
	to_date(a.maintcontractexpires,'$P!{DATE_FORMAT}') - now() < INTERVAL '$P!{WARNING_THRESHOLD_DAYS} days'
ORDER BY
	a.manufacturer ASC,
	a.maintcontractexpires DESC]]></query>
	<field name="nodelabel" class="java.lang.String"/>
	<field name="maintcontract" class="java.lang.String"/>
	<field name="manufacturer" class="java.lang.String"/>
	<field name="modelnumber" class="java.lang.String"/>
	<field name="operatingsystem" class="java.lang.String"/>
	<field name="serialnumber" class="java.lang.String"/>
	<field name="dateinstalled" class="java.sql.Date"/>
	<field name="vendorphone" class="java.lang.String"/>
	<field name="maintcontractexpires" class="java.sql.Date"/>
	<field name="maintcontractleft" class="org.postgresql.util.PGInterval"/>
	<field name="maintcontractstatus" class="java.lang.String"/>
	<variable name="variable1" class="java.lang.String"/>
	<filterExpression><![CDATA["true".equals($P{DISPLAY_EXPIRED}) ? !"".equals($F{maintcontractstatus}) : "warning".equals($F{maintcontractstatus})]]></filterExpression>
