	<dataset name="Measurement_Dataset" uuid="4db04fe1-cb7c-4fc9-a192-94ad606e483c">
		<parameter name="ds_ipv4_interface" class="java.lang.String"/>
		<parameter name="ds_startDateTime" forPrompting="false" class="java.util.Date"/>
		<parameter name="ds_endDateTime" forPrompting="false" class="java.util.Date"/>
		<parameter name="ds_nodeid" forPrompting="false" class="java.lang.String"/>
		<parameter name="ds_foreignsource" forPrompting="false" class="java.lang.String"/>
		<parameter name="ds_foreignid" forPrompting="false" class="java.lang.String"/>
		<parameter name="ds_categoryname" forPrompting="false" class="java.lang.String">
			<defaultValueExpression><![CDATA["Servers"]]></defaultValueExpression>
		</parameter>
		<parameter name="ds_nodeResourceDescriptor" forPrompting="false" class="java.lang.String">
			<defaultValueExpression><![CDATA[org.opennms.netmgt.jasper.helper.MeasurementsHelper.getNodeOrNodeSourceDescriptor($P{ds_nodeid}, $P{ds_foreignsource}, $P{ds_foreignid})]]></defaultValueExpression>
		</parameter>
		<parameter name="MEASUREMENT_URL" forPrompting="false" class="java.lang.String"/>
		<parameter name="MEASUREMENT_USERNAME" forPrompting="false" class="java.lang.String"/>
		<parameter name="MEASUREMENT_PASSWORD" forPrompting="false" class="java.lang.String"/>
		<query language="measurement"><![CDATA[<query-request step="300000" start="$P{ds_startDateTime}" end="$P{ds_endDateTime}" maxrows="2000">
  <source aggregation="AVERAGE" label="IcmpLatency" attribute="icmp" transient="false" resourceId="$P{ds_nodeResourceDescriptor}.responseTime[$P{ds_ipv4_interface}]"/>
</query-request>]]></query>
		<field name="timestamp" class="java.util.Date">
			<description><![CDATA[]]></description>
		</field>
		<field name="IcmpLatency" class="java.lang.Double">
			<description><![CDATA[]]></description>
		</field>
		<variable name="IcmpLatency_AVG" resetType="Group" calculation="Average" resetGroup="IPv4_interface_group" class="java.lang.Double">
			<expression><![CDATA[$F{IcmpLatency}]]></expression>
		</variable>
		<variable name="IcmpLatency_MAX" resetType="Group" calculation="Highest" resetGroup="IPv4_interface_group" class="java.lang.Double">
			<expression><![CDATA[$F{IcmpLatency}]]></expression>
		</variable>
		<variable name="IcmpLatency_MIN" resetType="Group" calculation="Lowest" resetGroup="IPv4_interface_group" class="java.lang.Double">
			<expression><![CDATA[$F{IcmpLatency}]]></expression>
			<initialValueExpression><![CDATA[]]></initialValueExpression>
		</variable>
		<variable name="Hour" resetType="Group" resetGroup="IPv4_interface_group" class="java.lang.Integer">
			<expression><![CDATA[Integer.valueOf($F{timestamp}.getHours())]]></expression>
		</variable>
		<group name="IPv4_interface_group">
			<expression><![CDATA[$P{ds_ipv4_interface}]]></expression>
		</group>
		<group name="hour_group">
			<expression><![CDATA[$V{Hour}]]></expression>
		</group>
	</dataset>
	<parameter name="ONMS_REPORT_DIR" forPrompting="false" class="java.lang.String">
		<description><![CDATA[The directory where all reports can be found]]></description>
		<defaultValueExpression><![CDATA["${install.dir}/etc/report-templates"]]></defaultValueExpression>
	</parameter>
