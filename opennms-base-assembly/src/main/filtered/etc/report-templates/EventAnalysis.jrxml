			<element kind="chart" chartType="timeSeries" uuid="b04b4451-706f-4f6f-ac46-6890c0a65201" positionType="Float" x="0" y="185" width="555" height="190" showLegend="false" titlePosition="Top">
				<titleFont fontSize="12.0" bold="true"/>
				<subtitleFont fontSize="10.0" italic="true"/>
				<titleExpression><![CDATA[new String("Total average processed events per hour")]]></titleExpression>
				<subtitleExpression><![CDATA[new String("last 30 days")]]></subtitleExpression>
				<dataset kind="timeSeries">
					<datasetRun uuid="d0665ce3-549f-4be7-9210-4f2a0f722d94" subDataset="events_eph"/>
					<series>
						<seriesExpression><![CDATA["day"]]></seriesExpression>
