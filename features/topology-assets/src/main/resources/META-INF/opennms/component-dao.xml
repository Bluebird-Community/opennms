<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xmlns:onmsgi="http://xmlns.opennms.org/xsd/spring/onms-osgi"
       xsi:schemaLocation="
           http://www.springframework.org/schema/beans
           http://www.springframework.org/schema/beans/spring-beans-4.2.xsd
           http://xmlns.opennms.org/xsd/spring/onms-osgi
           http://xmlns.opennms.org/xsd/spring/onms-osgi.xsd">

    <!-- Topology image assets (view backgrounds, custom node icons): bytes in
         the binary key-value store, metadata in the JSON key-value store. The
         shared 'jsonStore' and 'dataSource' beans come from the kv-store
         json/postgres context already on the DAO classpath (same reuse as the
         topology views DAO). The DAO builds its own PostgresBlobStore from the
         DataSource internally: the only BlobStore registered as a shared
         service in this context is thresholding's no-op, and exposing a second
         BlobStore bean/service would make that lookup ambiguous. -->
    <bean id="topologyAssetDao" class="org.opennms.netmgt.topology.assets.impl.TopologyAssetKvStore">
        <constructor-arg ref="jsonStore" />
        <constructor-arg ref="dataSource" />
    </bean>
    <onmsgi:service interface="org.opennms.netmgt.topology.assets.TopologyAssetDao" ref="topologyAssetDao" />

</beans>
