<?xml version="1.0"?>
<!-- NMS-18291: 64-bit UCD-SNMP memory gauges, applied to already-migrated
     databases by SnmpDataCollectionDefaultsUpdate. Must stay identical to the
     ucd-memory-X group shipped in etc/datacollection/netsnmp.xml so that the
     XML-migration path and the DB-delta path produce the same rows. -->
<datacollection-group xmlns="http://xmlns.opennms.org/xsd/config/datacollection" name="Net-SNMP">
   <group name="ucd-memory-X" ifType="ignore">
      <mibObj oid=".1.3.6.1.4.1.2021.4.18" instance="0" alias="memTotalSwapX" type="gauge"/>
      <mibObj oid=".1.3.6.1.4.1.2021.4.19" instance="0" alias="memAvailSwapX" type="gauge"/>
      <mibObj oid=".1.3.6.1.4.1.2021.4.20" instance="0" alias="memTotalRealX" type="gauge"/>
      <mibObj oid=".1.3.6.1.4.1.2021.4.21" instance="0" alias="memAvailRealX" type="gauge"/>
      <mibObj oid=".1.3.6.1.4.1.2021.4.22" instance="0" alias="memTotalFreeX" type="gauge"/>
      <mibObj oid=".1.3.6.1.4.1.2021.4.24" instance="0" alias="memSharedX" type="gauge"/>
      <mibObj oid=".1.3.6.1.4.1.2021.4.25" instance="0" alias="memBufferX" type="gauge"/>
      <mibObj oid=".1.3.6.1.4.1.2021.4.26" instance="0" alias="memCachedX" type="gauge"/>
      <mibObj oid=".1.3.6.1.4.1.2021.4.27" instance="0" alias="memSysAvail" type="integer"/>
   </group>
</datacollection-group>
