<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xmlns:onmsgi="http://xmlns.opennms.org/xsd/spring/onms-osgi"
       xmlns:util="http://www.springframework.org/schema/util"
       xsi:schemaLocation="http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans-4.2.xsd
        http://www.springframework.org/schema/util http://www.springframework.org/schema/util/spring-util-4.2.xsd
        http://xmlns.opennms.org/xsd/spring/onms-osgi http://xmlns.opennms.org/xsd/spring/onms-osgi.xsd">

    <!--
      Wires the runtime side of collector token authentication.

      TokenAuthConfigFactory is a static-singleton-style factory;
      TokenProviderImpl handles its lazy init internally so a clean install
      without etc/token-auth-configuration.xml degrades to "no
      token-auth definitions, every ${token:<name>} placeholder falls
      through" rather than failing at startup.
    -->

    <!--
      TokenAcquirer autowires EntityScopeProvider via @Autowired(required=false)
      on the setter so the bean wires up even in test contexts that don't
      define entityScopeProvider. The Java side handles a null provider
      gracefully by falling back to EmptyScope for SCV/ENV interpolation.
    -->
    <bean id="tokenAuthAcquirer"
          class="org.opennms.netmgt.config.tokenauth.TokenAcquirer"/>

    <bean id="tokenAuthCache"
          class="org.opennms.netmgt.config.tokenauth.TokenCache">
        <constructor-arg ref="tokenAuthAcquirer"/>
    </bean>

    <bean id="tokenAuthProvider"
          class="org.opennms.netmgt.config.tokenauth.TokenProviderImpl">
        <constructor-arg ref="tokenAuthCache"/>
    </bean>

    <!--
      Expose the TokenProvider as an OSGi service so the XML/JSON and HTTP
      collectors can autowire it without depending on opennms-config
      directly.
    -->
    <onmsgi:service interface="org.opennms.netmgt.config.tokenauth.TokenProvider"
                    ref="tokenAuthProvider"/>

    <!--
      Mate scope that resolves ${token:<name>} placeholders during
      parameter interpolation. EntityScopeProviderImpl binds this scope
      per-call (via BoundableScope) with the full per-node composite
      ambient (node attributes + asset + SCV + ENV), so the constructor
      argument here is just a placeholder. Using EmptyScope keeps the
      bean wiring self-contained. No hard dependency on
      entityScopeProvider at context-load time. Matters for
      tests that import component-dao.xml without defining one.
    -->
    <util:constant id="tokenAuthScopeDefaultAmbient"
                   static-field="org.opennms.core.mate.api.EmptyScope.EMPTY"/>

    <bean id="tokenAuthScope"
          class="org.opennms.netmgt.config.tokenauth.TokenAuthScope">
        <qualifier value="additionalScope"/>
        <constructor-arg ref="tokenAuthProvider"/>
        <constructor-arg ref="tokenAuthScopeDefaultAmbient"/>
    </bean>

    <!--
      Collector adaptor that records which token-auth names participated
      in a request so the cache can be invalidated when the collection
      comes back failed. Substitution itself is done by tokenAuthScope
      during Mate interpolation, before the adaptor runs.
    -->
    <bean id="tokenAuthCollectorAdaptor"
          class="org.opennms.netmgt.config.tokenauth.TokenAuthCollectorAdaptor">
        <constructor-arg ref="tokenAuthProvider"/>
    </bean>

    <onmsgi:service interface="org.opennms.netmgt.collection.api.CollectorAdaptor"
                    ref="tokenAuthCollectorAdaptor"/>

    <!--
      Reload listener: reacts to a reloadDaemonConfig event with
      daemonName=TokenAuth by re-reading
      token-auth-configuration.xml and flushing the token cache.

      Registration is lazy via ContextRefreshedEvent. This bean lives in
      daoContext, which is loaded as a parent of eventDaemonContext while
      that context is still being constructed, so eventIpcManager is not
      yet available at construction or init time. The listener watches
      for context-refresh events and registers once
      EventIpcManagerFactory reports a ready manager.
    -->
    <bean id="tokenAuthConfigReloadListener"
          class="org.opennms.netmgt.config.tokenauth.TokenAuthConfigReloadListener">
        <constructor-arg ref="tokenAuthCache"/>
    </bean>

</beans>
