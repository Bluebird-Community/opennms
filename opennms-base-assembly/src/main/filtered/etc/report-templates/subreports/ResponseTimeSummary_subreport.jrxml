			<expression><![CDATA[String.format("%.2f", $V{ICMP_Latency_AVG}/new Double("1000.0"))]]></expression>
		</element>
		<element kind="staticText" uuid="73ad83d1-8f7a-432f-99ec-404471f899d0" x="255" y="0" width="100" height="20" style="Sub-sub-sub-header">
			<text><![CDATA[Minimum (ms)]]></text>
		</element>
		<property name="local_mesure_unitheight" value="pixel"/>
