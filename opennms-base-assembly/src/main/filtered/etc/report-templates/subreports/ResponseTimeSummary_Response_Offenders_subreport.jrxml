				<expression><![CDATA[$V{RESPONSE_TIME}]]></expression>
			</element>
			<element kind="subreport" uuid="3b6eab8e-32d5-42f8-a6af-832a48e00ca5" stretchType="ContainerHeight" x="0" y="0" width="206" height="20">
