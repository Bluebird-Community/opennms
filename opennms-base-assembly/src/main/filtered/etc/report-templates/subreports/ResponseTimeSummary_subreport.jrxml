			<expression><![CDATA[String.format("%.2f", $V{ICMP_Latency_MAX}/new Double("1000.0"))]]></expression>
		</element>
		<element kind="staticText" uuid="7b8af5ce-5208-44ae-886a-89f2be2c3a24" x="455" y="0" width="100" height="20" style="Sub-sub-sub-header">
