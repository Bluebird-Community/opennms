			<text><![CDATA[Average (ms)]]></text>
		</element>
		<element kind="staticText" uuid="bf39f115-1ee8-42e1-83d6-26ddf7ac9b4c" x="25" y="0" width="230" height="20" hTextAlign="Left" style="Sub-sub-sub-header">
