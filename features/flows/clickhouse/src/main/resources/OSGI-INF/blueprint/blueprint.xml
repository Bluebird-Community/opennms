    ClickHouse flow persistence + query (flow-persistence-clickhouse).
    Config PID defaults, the schema bootstrap, the Path A ClickhouseFlowRepository
    (FlowRepository, flows.repository.id=clickhouse), the ClickhouseFlowQueryService
    (FlowQueryService) and the ClickHouse health check are all declared here.
-->
<blueprint xmlns="http://www.osgi.org/xmlns/blueprint/v1.0.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xmlns:cm="http://aries.apache.org/blueprint/xmlns/blueprint-cm/v1.1.0"
           xsi:schemaLocation="http://www.osgi.org/xmlns/blueprint/v1.0.0
		http://www.osgi.org/xmlns/blueprint/v1.0.0/blueprint.xsd

		http://aries.apache.org/blueprint/xmlns/blueprint-cm/v1.1.0
		http://aries.apache.org/schemas/blueprint-cm/blueprint-cm-1.1.0.xsd">

    <cm:property-placeholder id="clickhouseFlowProperties"
                             persistent-id="org.opennms.features.flows.persistence.clickhouse"
                             update-strategy="reload">
        <cm:default-properties>
            <!-- Connection -->
            <cm:property name="endpoint" value="http://localhost:8123" />
            <cm:property name="database" value="default" />
            <cm:property name="username" value="default" />
            <cm:property name="password" value="" />

            <!-- Schema / retention -->
            <cm:property name="table" value="flows" />
            <cm:property name="ttlDays" value="30" />

            <!-- Path A write path (in-process batch INSERT) -->
            <cm:property name="enablePersistence" value="true" />
            <cm:property name="bulkSize" value="1000" />
            <cm:property name="bulkFlushMs" value="500" />
            <cm:property name="maxBufferedFlows" value="100000" />
        </cm:default-properties>
    </cm:property-placeholder>

    <!-- Metrics -->
    <bean id="clickhouseFlowMetricRegistry" class="com.codahale.metrics.MetricRegistry"/>
    <service ref="clickhouseFlowMetricRegistry" interface="com.codahale.metrics.MetricSet">
        <service-properties>
            <entry key="name" value="org.opennms.netmgt.flows.clickhouse" />
            <entry key="description" value="ClickHouse Flow Repository" />
        </service-properties>
    </service>

    <!-- ClickHouse client -->
    <bean id="clickhouseClientFactory" class="org.opennms.netmgt.flows.clickhouse.ClickhouseClientFactory">
        <argument value="${endpoint}"/>
        <argument value="${username}"/>
        <argument value="${password}"/>
        <argument value="${database}"/>
    </bean>
    <bean id="clickhouseClient" factory-ref="clickhouseClientFactory" factory-method="createClient" destroy-method="close"/>

    <!-- Schema bootstrap (single source of truth for DDL; idempotent) -->
    <bean id="clickhouseSchemaBootstrap" class="org.opennms.netmgt.flows.clickhouse.ClickhouseSchemaBootstrap" init-method="initializeQuietly">
        <argument ref="clickhouseClient"/>
        <argument value="${ttlDays}"/>
    </bean>

    <!-- Path A: in-process write repository -->
    <bean id="clickhouseFlowRepository" class="org.opennms.netmgt.flows.clickhouse.ClickhouseFlowRepository"
          init-method="start" destroy-method="stop" depends-on="clickhouseSchemaBootstrap">
        <argument ref="clickhouseFlowMetricRegistry"/>
        <argument ref="clickhouseClient"/>
        <argument value="${table}"/>
        <property name="bulkSize" value="${bulkSize}"/>
        <property name="bulkFlushMs" value="${bulkFlushMs}"/>
        <property name="maxBufferedFlows" value="${maxBufferedFlows}"/>
    </bean>
    <bean id="switchedClickhouseFlowRepository" class="org.opennms.netmgt.flows.processing.persisting.SwitchedFlowRepository">
        <argument ref="clickhouseFlowRepository"/>
        <property name="enabled" value="${enablePersistence}"/>
    </bean>
    <service interface="org.opennms.integration.api.v1.flows.FlowRepository" ref="switchedClickhouseFlowRepository">
        <service-properties>
            <entry key="flows.repository.id" value="clickhouse"/>
        </service-properties>
    </service>

    <!-- Read path: the ClickHouse-backed FlowQueryService (defaults are sane; rollup routing off). -->
    <bean id="clickhouseFlowQueryService" class="org.opennms.netmgt.flows.clickhouse.ClickhouseFlowQueryService">
        <argument ref="clickhouseClient"/>
        <argument value="${table}"/>
    </bean>
    <service interface="org.opennms.netmgt.flows.api.FlowQueryService" ref="clickhouseFlowQueryService"/>

    <!-- Health check: SELECT 1 against ClickHouse; reports "Not configured" when the PID is unset. -->
    <reference id="configurationAdmin" interface="org.osgi.service.cm.ConfigurationAdmin"/>
    <service interface="org.opennms.core.health.api.HealthCheck">
        <bean class="org.opennms.netmgt.flows.clickhouse.ClickhouseHealthCheck">
            <argument ref="clickhouseClient"/>
            <argument value="Flows"/>
            <argument ref="configurationAdmin"/>
            <argument value="org.opennms.features.flows.persistence.clickhouse"/>
        </bean>
    </service>

</blueprint>
