		</variable>
		<variable name="SURVEILLANCE_CAT_AVAILABILITY_AVG" resetType="Group" calculation="Average" resetGroup="SURVEILLANCE_CAT" class="java.lang.Double">
			<expression><![CDATA[$F{avail_percent}]]></expression>
		</variable>
		<variable name="SURVEILLANCE_CAT_AVAILABILITY_MAX" resetType="Group" calculation="Highest" resetGroup="SURVEILLANCE_CAT" class="java.lang.Double">
			<expression><![CDATA[$F{avail_percent}]]></expression>
		</variable>
		<variable name="SURVEILLANCE_CAT_AVAILABILITY_MIN" resetType="Group" calculation="Lowest" resetGroup="SURVEILLANCE_CAT" class="java.lang.Double">
			<expression><![CDATA[$F{avail_percent}]]></expression>
		</variable>
		<variable name="SURVEILLANCE_CAT_OUTAGES_AVG" resetType="Group" calculation="Average" resetGroup="SURVEILLANCE_CAT" class="java.lang.Double">
			<expression><![CDATA[$F{outages_percent}]]></expression>
		</variable>
		<variable name="SURVEILLANCE_CAT_OUTAGES_MAX" resetType="Group" calculation="Highest" resetGroup="SURVEILLANCE_CAT" class="java.lang.Double">
			<expression><![CDATA[$F{outages_percent}]]></expression>
		</variable>
		<variable name="SURVEILLANCE_CAT_OUTAGES_MIN" resetType="Group" calculation="Lowest" resetGroup="SURVEILLANCE_CAT" class="java.lang.Double">
			<expression><![CDATA[$F{outages_percent}]]></expression>
		</variable>
		<variable name="SURVEILLANCE_CAT_TOTAL_AVG" resetType="Group" calculation="Average" resetGroup="SURVEILLANCE_CAT" class="java.lang.Double">
			<expression><![CDATA[$F{outages_seconds}/new Double("3600")]]></expression>
		</variable>
		<variable name="SURVEILLANCE_CAT_TOTAL_MAX" resetType="Group" calculation="Highest" resetGroup="SURVEILLANCE_CAT" class="java.lang.Double">
			<expression><![CDATA[$F{outages_seconds}/new Double("3600")]]></expression>
		</variable>
		<variable name="SURVEILLANCE_CAT_TOTAL_MIN" resetType="Group" calculation="Lowest" resetGroup="SURVEILLANCE_CAT" class="java.lang.Double">
			<expression><![CDATA[$F{outages_seconds}/new Double("3600")]]></expression>
		</variable>
		<variable name="SURVEILLANCE_CAT_MTTR_AVG" resetType="Group" calculation="Average" resetGroup="SURVEILLANCE_CAT" class="java.lang.Double">
			<expression><![CDATA[$F{average_duration_seconds}/new Double("3600")]]></expression>
		</variable>
		<variable name="SURVEILLANCE_CAT_MTTR_MAX" resetType="Group" calculation="Highest" resetGroup="SURVEILLANCE_CAT" class="java.lang.Double">
			<expression><![CDATA[$F{average_duration_seconds}/new Double("3600")]]></expression>
		</variable>
		<variable name="SURVEILLANCE_CAT_MTTR_MIN" resetType="Group" calculation="Lowest" resetGroup="SURVEILLANCE_CAT" class="java.lang.Double">
			<expression><![CDATA[$F{average_duration_seconds}/new Double("3600")]]></expression>
		</variable>
		<variable name="SURVEILLANCE_CAT_CNT_AVG" resetType="Group" calculation="Average" resetGroup="SURVEILLANCE_CAT" class="java.lang.Long">
			<expression><![CDATA[$F{outages_count}]]></expression>
		</variable>
		<variable name="SURVEILLANCE_CAT_CNT_MAX" resetType="Group" calculation="Highest" resetGroup="SURVEILLANCE_CAT" class="java.lang.Long">
			<expression><![CDATA[$F{outages_count}]]></expression>
		</variable>
		<variable name="SURVEILLANCE_CAT_CNT_MIN" resetType="Group" calculation="Lowest" resetGroup="SURVEILLANCE_CAT" class="java.lang.Long">
			<expression><![CDATA[$F{outages_count}]]></expression>
		</variable>
		<group name="SURVEILLANCE_CAT">
			<expression><![CDATA[$F{categoryname}]]></expression>
		</group>
	</dataset>
