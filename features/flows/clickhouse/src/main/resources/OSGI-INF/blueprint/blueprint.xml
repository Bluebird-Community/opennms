    ClickHouse flow persistence + query (flow-persistence-clickhouse).
    Skeleton: config PID defaults are declared here. The schema bootstrap,
    the Path A ClickhouseFlowRepository (FlowRepository, flows.repository.id=clickhouse),
    the ClickhouseFlowQueryService (FlowQueryService), and the health check are added in
    tasks 1.5, 2.4, 3.8 respectively.
-->
<blueprint xmlns="http://www.osgi.org/xmlns/blueprint/v1.0.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xmlns:cm="http://aries.apache.org/blueprint/xmlns/blueprint-cm/v1.1.0"
           xsi:schemaLocation="http://www.osgi.org/xmlns/blueprint/v1.0.0
		http://www.osgi.org/xmlns/blueprint/v1.0.0/blueprint.xsd

		http://aries.apache.org/blueprint/xmlns/blueprint-cm/v1.1.0
		http://aries.apache.org/schemas/blueprint-cm/blueprint-cm-1.1.0.xsd">

    <cm:property-placeholder id="clickhouseFlowProperties"
                             persistent-id="org.opennms.features.flows.persistence.clickhouse"
                             update-strategy="reload">
        <cm:default-properties>
            <!-- Connection -->
            <cm:property name="endpoint" value="http://localhost:8123" />
            <cm:property name="database" value="default" />
            <cm:property name="username" value="default" />
            <cm:property name="password" value="" />

            <!-- Schema / retention -->
            <cm:property name="table" value="flows" />
            <cm:property name="ttlDays" value="30" />

            <!-- Path A write path (in-process batch INSERT) -->
            <cm:property name="enablePersistence" value="true" />
            <cm:property name="bulkSize" value="1000" />
            <cm:property name="bulkFlushMs" value="500" />
        </cm:default-properties>
    </cm:property-placeholder>

    <!-- Metrics -->
    <bean id="clickhouseFlowMetricRegistry" class="com.codahale.metrics.MetricRegistry"/>
    <service ref="clickhouseFlowMetricRegistry" interface="com.codahale.metrics.MetricSet">
        <service-properties>
            <entry key="name" value="org.opennms.netmgt.flows.clickhouse" />
            <entry key="description" value="ClickHouse Flow Repository" />
        </service-properties>
    </service>

</blueprint>
