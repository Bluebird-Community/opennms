		<variable name="interface_outages_SUM" calculation="Sum" class="java.lang.Integer">
			<expression><![CDATA[$F{interface_outage_24h}]]></expression>
			<initialValueExpression><![CDATA[new Integer("0")]]></initialValueExpression>
		</variable>
		<variable name="service_outages_SUM" calculation="Sum" class="java.lang.Integer">
			<expression><![CDATA[$F{service_outage_24h}]]></expression>
			<initialValueExpression><![CDATA[new Integer("0")]]></initialValueExpression>
		</variable>
		<variable name="management_outages_SUM" calculation="Sum" class="java.lang.Integer">
			<expression><![CDATA[$F{management_outage_24h}]]></expression>
			<initialValueExpression><![CDATA[new Integer("0")]]></initialValueExpression>
		</variable>
		<group name="node_outages">
			<expression><![CDATA[$F{node_outage_24h}]]></expression>
		</group>
		<group name="interface_outages">
			<expression><![CDATA[$F{interface_outage_24h}]]></expression>
		</group>
		<group name="service_outages">
			<expression><![CDATA[$F{service_outage_24h}]]></expression>
		</group>
		<group name="management_outages">
			<expression><![CDATA[$F{management_outage_24h}]]></expression>
		</group>
	</dataset>
	<dataset name="notification_statistics" uuid="178ac654-e3b8-4d28-84b0-5165d976d2ec">
		<parameter name="notification_state" class="java.lang.String">
			<defaultValueExpression><![CDATA["acknowledged"]]></defaultValueExpression>
		</parameter>
		<query language="sql"><![CDATA[SELECT
	outstanding, acknowledged, state, userid, media
FROM
	(SELECT
		CASE
			WHEN notifications.answeredby is null THEN CAST('1' AS INTEGER)
			ELSE CAST('0' AS INTEGER)
			END AS outstanding,
		CASE
			WHEN notifications.answeredby is not null THEN CAST('1' AS INTEGER)
			ELSE CAST('0' AS INTEGER)
			END AS acknowledged,
		CASE
			WHEN notifications.answeredby is null THEN 'outstanding'
			ELSE 'acknowledged'
		END AS state,
		userid,
		media
	FROM
		notifications
	JOIN
		usersnotified
	ON
		(notifications.notifyid=usersnotified.notifyid)
	WHERE
		notifications.pagetime > now() - INTERVAL '23 hour'
	ORDER BY
		state, userid, media)
	AS notifications_24h
WHERE
	state like $P{notification_state}]]></query>
		<field name="outstanding" class="java.lang.Integer">
			<description><![CDATA[]]></description>
		</field>
		<field name="acknowledged" class="java.lang.Integer">
			<description><![CDATA[]]></description>
		</field>
		<field name="state" class="java.lang.String">
			<description><![CDATA[]]></description>
		</field>
		<field name="userid" class="java.lang.String">
			<description><![CDATA[]]></description>
		</field>
		<field name="media" class="java.lang.String">
			<description><![CDATA[]]></description>
		</field>
		<variable name="notified_acked_SUM" calculation="Sum" class="java.lang.Integer">
			<expression><![CDATA[$F{acknowledged}]]></expression>
			<initialValueExpression><![CDATA[new Integer("0")]]></initialValueExpression>
		</variable>
		<variable name="notified_outstanding_SUM" calculation="Sum" class="java.lang.Integer">
			<expression><![CDATA[$F{outstanding}]]></expression>
			<initialValueExpression><![CDATA[new Integer("0")]]></initialValueExpression>
		</variable>
		<group name="notification_state">
			<expression><![CDATA[$F{state}]]></expression>
		</group>
		<group name="notified_user">
			<expression><![CDATA[$F{userid}]]></expression>
		</group>
		<group name="notification_media">
			<expression><![CDATA[$F{media}]]></expression>
		</group>
	</dataset>
	<parameter name="ONMS_REPORT_DIR" forPrompting="false" class="java.lang.String">
		<description><![CDATA[The directory where all reports can be found]]></description>
		<defaultValueExpression><![CDATA["${install.dir}/etc/report-templates"]]></defaultValueExpression>
	</parameter>
