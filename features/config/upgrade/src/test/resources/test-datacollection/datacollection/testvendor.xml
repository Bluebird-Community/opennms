<datacollection-group xmlns="http://xmlns.opennms.org/xsd/config/datacollection" name="TestVendor">

    <resourceType name="ciscoMemoryPoolType" label="Cisco Memory Pool" resourceLabel="${ciscoMemoryPoolName}">
        <persistenceSelectorStrategy class="org.opennms.netmgt.collection.support.PersistAllSelectorStrategy"/>
        <storageStrategy class="org.opennms.netmgt.collection.support.IndexStorageStrategy"/>
    </resourceType>

    <group name="vendor-memory" ifType="all">
        <mibObj oid=".1.3.6.1.4.1.9.9.48.1.1.1.5" instance="ciscoMemoryPoolType" alias="ciscoMemPoolUsed" type="gauge"/>
        <mibObj oid=".1.3.6.1.4.1.9.9.48.1.1.1.6" instance="ciscoMemoryPoolType" alias="ciscoMemPoolFree" type="gauge"/>
    </group>

    <systemDef name="Cisco Routers">
        <sysoid>.1.3.6.1.4.1.9</sysoid>
        <collect>
            <includeGroup>vendor-memory</includeGroup>
        </collect>
    </systemDef>

</datacollection-group>
