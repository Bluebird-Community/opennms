<jasperReport name="assetMgmtStrategic" language="java" pageWidth="595" pageHeight="842" columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="74d8d5da-3ed5-4f83-9373-3eea8d213ca5">
	<property name="ireport.zoom" value="1.2100000000000002"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<template><![CDATA[$P{ONMS_REPORT_DIR} + "/assets/styles/defaultStyles.jrtx"]]></template>
	<dataset name="summaryNodeAge" uuid="2c371de7-9fb3-4d97-91a9-1dc79e3a2ed4">
		<parameter name="DS_DATE_FORMAT" forPrompting="false" class="java.lang.String">
			<description><![CDATA[]]></description>
			<defaultValueExpression><![CDATA["YYYY-MM-DD"]]></defaultValueExpression>
		</parameter>
		<query language="sql"><![CDATA[SELECT
	age,
	CASE
		WHEN
			contractleft is NULL
		THEN
			'no contract'
		WHEN
			contractleft < 0
		THEN
			'contract expired'
		WHEN
			contractleft > 0
		THEN
			'with contract'
	END AS contractstatus,
	sum(tally)
FROM
	(SELECT
		((EXTRACT(days from (now() - to_date(dateinstalled, '$P!{DS_DATE_FORMAT}'))))/365)::INTEGER AS age,
		CASE
			WHEN
				maintcontractexpires = ''
			THEN
				NULL
			ELSE
				EXTRACT(epoch from (to_date(maintcontractexpires,'$P!{DS_DATE_FORMAT}') - now()))
		END AS contractleft,
		count(*) AS tally
	FROM
		assets
	WHERE
		assets.maintcontractexpires != 'n.v.' AND
		assets.dateinstalled != 'n.v.' AND
		assets.dateinstalled != ''
	GROUP BY
		age,
		contractleft
	ORDER BY
		age
	) AS nodeAge
GROUP BY
	age,
	contractstatus
ORDER BY
	age,
	contractstatus]]></query>
		<field name="age" class="java.lang.Integer"/>
		<field name="contractstatus" class="java.lang.String"/>
		<field name="sum" class="java.math.BigDecimal"/>
	</dataset>
	<dataset name="maintContractExpiresPerMonth" uuid="1a49220c-0c3a-4f07-8ef5-d68eefcbc449">
		<parameter name="DS_DATE_FORMAT" forPrompting="false" class="java.lang.String">
			<defaultValueExpression><![CDATA["YYYY-MM-DD"]]></defaultValueExpression>
		</parameter>
		<query language="sql"><![CDATA[SELECT
	to_char(dates, 'YYYY-MM') AS yearmonth,
	dates
FROM
	(SELECT
		mytimequery.mytime::DATE AS dates
	FROM
		(SELECT
			(now() + myintervalquery.myinterval::INTERVAL)::DATE AS mytime
		 FROM
			(SELECT
				(s.t ||' month')::INTERVAL AS myinterval
			FROM
				generate_series(0,11) AS s(t)
			)
			AS myintervalquery

		)
		AS mytimequery
	) AS generatedMonth
LEFT JOIN
	assets
ON
	(to_char((to_date(assets.maintcontractexpires,'$P!{DS_DATE_FORMAT}')),'YYYY-MM') =
	to_char(generatedMonth.dates, 'YYYY-MM') AND assets.maintcontractexpires != 'n.v.')
ORDER BY
	yearmonth]]></query>
		<field name="yearmonth" class="java.lang.String"/>
		<field name="dates" class="java.sql.Date"/>
		<group name="yearmonth">
			<expression><![CDATA[$F{yearmonth}]]></expression>
		</group>
	</dataset>
	<dataset name="maintcontractSummary" uuid="414333b8-7cab-45fb-9351-af50c168d405">
		<parameter name="DS_DATE_FORMAT" forPrompting="false" class="java.lang.String">
			<defaultValueExpression><![CDATA["YYYY-MM-DD"]]></defaultValueExpression>
		</parameter>
		<query language="sql"><![CDATA[SELECT
	CASE
		WHEN
			maintcontract = '' OR maintcontract is null OR maintcontract = ' '
			THEN
				'no contract'
		WHEN
			maintcontract = 'n.v.'
			THEN
				'no contract'
		WHEN
			EXTRACT(epoch from (to_date(maintcontractexpires,'$P!{DS_DATE_FORMAT}') - now())) > 0
			THEN 'in contract'
		WHEN
			EXTRACT(epoch from (to_date(maintcontractexpires,'$P!{DS_DATE_FORMAT}') - now())) < 0
			THEN 'expired'
		ELSE
			'UNKNOWN'
	END AS contractstatus,
	count(*) AS tally
FROM
	(SELECT
		maintcontract,
		maintcontractexpires
	FROM
		assets
	JOIN
		node
	ON
		(assets.nodeid = node.nodeid)
	WHERE
		node.nodetype = 'A'
	ORDER BY
		maintcontract
	) AS maintenancecontracts
GROUP BY
	contractstatus
ORDER BY
	contractstatus]]></query>
		<field name="contractstatus" class="java.lang.String"/>
		<field name="tally" class="java.lang.Long"/>
	</dataset>
	<parameter name="ONMS_REPORT_DIR" forPrompting="false" class="java.lang.String">
		<description><![CDATA[The directory where all reports can be found]]></description>
		<defaultValueExpression><![CDATA["${install.dir}/etc/report-templates"]]></defaultValueExpression>
	</parameter>
	<parameter name="DATE_FORMAT" class="java.lang.String">
		<description><![CDATA[Your date format in maintenance contracts. Default is "YYYY-MM-DD"]]></description>
		<defaultValueExpression><![CDATA["YYYY-MM-DD"]]></defaultValueExpression>
	</parameter>
