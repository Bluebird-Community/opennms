			<expression><![CDATA[$V{RECEIVED_BYTES_TOTAL} > 1000000000 ? String.format("%10.2f", $V{RECEIVED_BYTES_TOTAL}/new Double("1000000000.0")) + " GB" : ($V{RECEIVED_BYTES_TOTAL} > 1000000 ? String.format("%10.2f", $V{RECEIVED_BYTES_TOTAL}/new Double("1000000.0")) + " MB" : String.format("%10.2f", $V{RECEIVED_BYTES_TOTAL}/new Double("1000.0")) + " KB")]]></expression>
		</element>
		<element kind="textField" uuid="da98f4d2-e819-4f5c-b880-5298664406e2" x="186" y="16" width="150" height="16" pattern="###0.00" style="Table-Body">
